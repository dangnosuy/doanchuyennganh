<mxGraphModel adaptiveColors="0" background="#ffffff">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Row 1 (L→R): Hunter → Red/Blue debate → Exec -->
    <mxCell id="hunter" value="Hunter Agent&#xa;(LLM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="155" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="red" value="Red Agent&#xa;(Attacker, LLM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="265" y="30" width="155" height="55" as="geometry"/>
    </mxCell>

    <mxCell id="blue" value="Blue Agent&#xa;(Skeptic, LLM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="265" y="105" width="155" height="55" as="geometry"/>
    </mxCell>

    <mxCell id="exec" value="Exec Agent&#xa;(Tool-calling LLM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="490" y="60" width="170" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 2 (R→L): ProofGate ← Verifier Panel -->
    <mxCell id="verifier" value="Verifier Panel&#xa;(3× LLM, majority vote)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="490" y="230" width="200" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="proofgate" value="ProofGate&#xa;(Deterministic Code&#xa;— AI cannot override)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="245" y="223" width="185" height="75" as="geometry"/>
    </mxCell>

    <!-- Output -->
    <mxCell id="verdict" value="Verdict&#xa;EXPLOITED / PROOF_FAIL&#xa;/ NOT_EXPLOITED" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=8;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="40" y="230" width="175" height="75" as="geometry"/>
    </mxCell>

    <!-- Data docs: StrategyDocument -->
    <mxCell id="strat" value="StrategyDocument&#xa;(frozen — READ-ONLY)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555555;fontSize=10;fontColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="265" y="168" width="155" height="50" as="geometry"/>
    </mxCell>

    <!-- Edges Row 1 -->
    <mxCell id="eb1" value="BugDossier" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#555555;" edge="1" source="hunter" target="red" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="eb2" value="debate" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#b85450;" edge="1" source="red" target="blue" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="eb2b" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;" edge="1" source="blue" target="red" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="eb3" value="APPROVE" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#555555;" edge="1" source="blue" target="strat" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="eb4" value="READ-ONLY" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#d79b00;fontColor=#d79b00;fontStyle=1;" edge="1" source="strat" target="exec" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edges Row 2 (snake down from Exec) -->
    <mxCell id="eb5" value="Evidence&#xa;(HttpExchange)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#555555;" edge="1" source="exec" target="verifier" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="eb6" value="panel_verdicts" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#555555;" edge="1" source="verifier" target="proofgate" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="eb7" value="sets verdict" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#82b366;fontColor=#2d7600;fontStyle=1;" edge="1" source="proofgate" target="verdict" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
